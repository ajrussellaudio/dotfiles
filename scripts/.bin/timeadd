#!/usr/bin/env node

const input = process.argv[2];

if (!input) {
  console.error("Usage: timeadd <duration>  e.g. timeadd 2h30m, timeadd 1d3h40m");
  process.exit(1);
}

const match = input.match(/^(?:(\d+)d)?(?:(\d+)h)?(?:(\d+)m)?$/);
if (!match || (!match[1] && !match[2] && !match[3])) {
  console.error(`Invalid duration: "${input}". Use formats like 1d2h30m, 2h30m, 2h, or 90m`);
  process.exit(1);
}

const days = parseInt(match[1] || "0", 10);
const hours = parseInt(match[2] || "0", 10);
const minutes = parseInt(match[3] || "0", 10);
const totalMinutes = days * 24 * 60 + hours * 60 + minutes;

const now = new Date();
const result = new Date(now.getTime() + totalMinutes * 60 * 1000);

const pad = (n) => String(n).padStart(2, "0");
const time = `${pad(result.getHours())}:${pad(result.getMinutes())}`;

const todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate());
const resultStart = new Date(result.getFullYear(), result.getMonth(), result.getDate());
const dayDiff = Math.round((resultStart - todayStart) / (1000 * 60 * 60 * 24));

if (dayDiff === 0) {
  console.log(time);
} else if (dayDiff === 1) {
  console.log(`${time} (tomorrow)`);
} else {
  const dayName = result.toLocaleDateString("en-GB", { weekday: "long" });
  const day = result.getDate();
  const month = result.toLocaleDateString("en-GB", { month: "short" });
  console.log(`${time} (${dayName} ${day} ${month})`);
}
