jq -r ".scripts | to_entries[] | [.key, .value] | @tsv" ./package.json | column -t -s $'\t' |
  fzf --delimiter '\s\s+' --accept-nth=1 --tmux 40% --bind 'enter:become:pnpm run {1}'
